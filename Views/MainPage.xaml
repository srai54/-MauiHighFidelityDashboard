<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:HighFidelity.Ui.Components"
             xmlns:vm="clr-namespace:HighFidelity.Ui.ViewModels"
             xmlns:models="clr-namespace:HighFidelity.Ui.Models"
             x:Class="HighFidelity.Ui.Views.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False"
             Title="Dashboard">
    <Grid x:Name="RootGrid" ColumnDefinitions="200,*">
        <components:SidebarView x:Name="Sidebar" SelectItemCommand="{Binding NavigateCommand}" />

        <ScrollView x:Name="MainScroll" Grid.Column="1">
            <VerticalStackLayout x:Name="ContentStack" Padding="12" Spacing="8">

                <!-- Row 1: merged Dashboard card (header + spline chart + stat strip) and Traffic card -->
                <Grid x:Name="TopRowGrid" ColumnDefinitions="2.55*,1*" ColumnSpacing="8">
                    <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                        <Grid RowDefinitions="*,1,Auto">
                            <Grid x:Name="HeaderChartGrid" ColumnDefinitions="205,*" ColumnSpacing="24" RowSpacing="20" Padding="20,18,20,10">
                                <components:DashboardHeaderView />
                                <components:SalesChartView x:Name="ChartView" Grid.Column="1" />
                            </Grid>
                            <BoxView Grid.Row="1" HeightRequest="1" Color="{StaticResource DividerColor}" />
                            <Grid x:Name="SummaryStrip"
                                  Grid.Row="2"
                                  ColumnDefinitions="*,1,*,1,*,1,*"
                                  RowSpacing="16"
                                  Padding="20,16">
                                <components:SummaryCardView x:Name="SummaryWallet" BindingContext="{Binding WalletCard}" />
                                <BoxView x:Name="SummaryDiv1" Grid.Column="1" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView x:Name="SummaryReferral" Grid.Column="2" Margin="18,0,0,0" BindingContext="{Binding ReferralCard}" />
                                <BoxView x:Name="SummaryDiv2" Grid.Column="3" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView x:Name="SummaryEstimate" Grid.Column="4" Margin="18,0,0,0" BindingContext="{Binding EstimateCard}" />
                                <BoxView x:Name="SummaryDiv3" Grid.Column="5" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView x:Name="SummaryEarning" Grid.Column="6" Margin="18,0,0,0" BindingContext="{Binding EarningCard}" />
                            </Grid>
                        </Grid>
                    </Border>
                    <components:TrafficChartView x:Name="TrafficChart" Grid.Column="1" ItemsSource="{Binding TrafficSources}" />
                </Grid>

                <!-- Row 2: analytics cards. Columns mirror the top row (0.85*3 = 2.55) so the
                     last card lines up exactly under the Traffic card. -->
                <Grid x:Name="RevenueRowGrid"
                      ColumnDefinitions="0.85*,0.85*,0.85*,*"
                      ColumnSpacing="8"
                      RowSpacing="8">
                    <components:RevenueCardView
                        x:Name="RevCard1"
                        CardTitle="{Binding RevenueStatusCard.Title}"
                        CardValue="{Binding RevenueStatusCard.Value}"
                        CardSubtitle="{Binding RevenueStatusCard.Subtitle}"
                        ChartType="{Binding RevenueStatusCard.ChartType}"
                        CardBackground="{Binding RevenueStatusCard.BackgroundHex, Converter={StaticResource HexToColorConverter}}"
                        AccentColor="{Binding RevenueStatusCard.AccentHex, Converter={StaticResource HexToColorConverter}}" />
                    <components:RevenueCardView
                        x:Name="RevCard2"
                        Grid.Column="1"
                        CardTitle="{Binding PageViewCard.Title}"
                        CardValue="{Binding PageViewCard.Value}"
                        CardSubtitle="{Binding PageViewCard.Subtitle}"
                        ChartType="{Binding PageViewCard.ChartType}"
                        CardBackground="{Binding PageViewCard.BackgroundHex, Converter={StaticResource HexToColorConverter}}"
                        AccentColor="{Binding PageViewCard.AccentHex, Converter={StaticResource HexToColorConverter}}" />
                    <components:RevenueCardView
                        x:Name="RevCard3"
                        Grid.Column="2"
                        CardTitle="{Binding BounceRateCard.Title}"
                        CardValue="{Binding BounceRateCard.Value}"
                        CardSubtitle="{Binding BounceRateCard.Subtitle}"
                        ChartType="{Binding BounceRateCard.ChartType}"
                        CardBackground="{Binding BounceRateCard.BackgroundHex, Converter={StaticResource HexToColorConverter}}"
                        AccentColor="{Binding BounceRateCard.AccentHex, Converter={StaticResource HexToColorConverter}}" />
                    <components:RevenueCardView
                        x:Name="RevCard4"
                        Grid.Column="3"
                        CardTitle="{Binding RevenueStatusAltCard.Title}"
                        CardValue="{Binding RevenueStatusAltCard.Value}"
                        CardSubtitle="{Binding RevenueStatusAltCard.Subtitle}"
                        ChartType="{Binding RevenueStatusAltCard.ChartType}"
                        CardBackground="{Binding RevenueStatusAltCard.BackgroundHex, Converter={StaticResource HexToColorConverter}}"
                        AccentColor="{Binding RevenueStatusAltCard.AccentHex, Converter={StaticResource HexToColorConverter}}" />
                </Grid>

                <!-- Row 3: Recent Activities + Order Status -->
                <Grid x:Name="BottomRowGrid" ColumnDefinitions="2*,3*" ColumnSpacing="8">
                    <components:ActivityTimelineView />
                    <components:OrderTableView x:Name="OrderTable" Grid.Column="1" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Hamburger: only on narrow screens, toggles the sidebar overlay -->
        <Button x:Name="MenuButton"
                Grid.Column="1"
                Text="&#xf0c9;"
                FontFamily="FontAwesome"
                FontSize="16"
                TextColor="{StaticResource TextPrimary}"
                BackgroundColor="White"
                BorderColor="{StaticResource DividerColor}"
                BorderWidth="1"
                CornerRadius="6"
                WidthRequest="40"
                HeightRequest="40"
                Padding="0"
                Margin="10"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                IsVisible="False"
                ZIndex="20"
                Clicked="OnMenuClicked" />

        <ActivityIndicator Grid.Column="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource PrimaryOrange}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>
