<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:MauiHighFidelityDashboard.Components"
             xmlns:vm="clr-namespace:MauiHighFidelityDashboard.ViewModels"
             xmlns:models="clr-namespace:MauiHighFidelityDashboard.Models"
             x:Class="MauiHighFidelityDashboard.Views.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False"
             Title="Dashboard">
    <Grid x:Name="RootGrid" ColumnDefinitions="200,*">
        <components:SidebarView x:Name="Sidebar" SelectItemCommand="{Binding NavigateCommand}" />

        <ScrollView x:Name="MainScroll" Grid.Column="1">
            <VerticalStackLayout x:Name="ContentStack" Padding="18" Spacing="16">

                <!-- Row 1: merged Dashboard card (header + spline chart + stat strip) and Traffic card -->
                <Grid x:Name="TopRowGrid" ColumnDefinitions="2.55*,1*" ColumnSpacing="16" RowSpacing="16">
                    <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                        <Grid RowDefinitions="*,1,Auto">
                            <Grid x:Name="HeaderChartGrid" ColumnDefinitions="205,*" ColumnSpacing="24" RowSpacing="20" Padding="20,18,20,10">
                                <components:DashboardHeaderView />
                                <components:SalesChartView x:Name="ChartView" Grid.Column="1" />
                            </Grid>
                            <BoxView Grid.Row="1" HeightRequest="1" Color="{StaticResource DividerColor}" />
                            <Grid x:Name="SummaryStrip"
                                  Grid.Row="2"
                                  ColumnDefinitions="*,1,*,1,*,1,*"
                                  RowSpacing="16"
                                  Padding="20,16">
                                <components:SummaryCardView x:Name="SummaryWallet" BindingContext="{Binding WalletCard}" />
                                <BoxView x:Name="SummaryDiv1" Grid.Column="1" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView x:Name="SummaryReferral" Grid.Column="2" Margin="18,0,0,0" BindingContext="{Binding ReferralCard}" />
                                <BoxView x:Name="SummaryDiv2" Grid.Column="3" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView x:Name="SummaryEstimate" Grid.Column="4" Margin="18,0,0,0" BindingContext="{Binding EstimateCard}" />
                                <BoxView x:Name="SummaryDiv3" Grid.Column="5" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView x:Name="SummaryEarning" Grid.Column="6" Margin="18,0,0,0" BindingContext="{Binding EarningCard}" />
                            </Grid>
                        </Grid>
                    </Border>
                    <components:TrafficChartView x:Name="TrafficChart" Grid.Column="1" />
                </Grid>

                <!-- Row 2: analytics cards. Wrap + 240px basis reflows them 4 / 2 / 1 per row as width shrinks -->
                <FlexLayout x:Name="RevenueFlex" Direction="Row" Wrap="Wrap" AlignItems="Stretch"
                            BindableLayout.ItemsSource="{Binding RevenueCards}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:RevenueCardItem">
                            <components:RevenueCardView
                                Margin="8,0"
                                CardTitle="{Binding Title}"
                                CardValue="{Binding Value}"
                                CardSubtitle="{Binding Subtitle}"
                                ChartType="{Binding ChartType}"
                                CardBackground="{Binding BackgroundHex, Converter={StaticResource HexToColorConverter}}"
                                AccentColor="{Binding AccentHex, Converter={StaticResource HexToColorConverter}}"
                                FlexLayout.Basis="240"
                                FlexLayout.Grow="1" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- Row 3: Recent Activities + Order Status -->
                <Grid x:Name="BottomRowGrid" ColumnDefinitions="2*,3*" ColumnSpacing="16" RowSpacing="16">
                    <components:ActivityTimelineView />
                    <components:OrderTableView x:Name="OrderTable" Grid.Column="1" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Hamburger: only on narrow screens, toggles the sidebar overlay -->
        <Button x:Name="MenuButton"
                Grid.Column="1"
                Text="☰"
                FontSize="16"
                TextColor="{StaticResource TextPrimary}"
                BackgroundColor="White"
                BorderColor="{StaticResource DividerColor}"
                BorderWidth="1"
                CornerRadius="6"
                WidthRequest="40"
                HeightRequest="40"
                Padding="0"
                Margin="10"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                IsVisible="False"
                ZIndex="20"
                Clicked="OnMenuClicked" />

        <ActivityIndicator Grid.Column="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource PrimaryOrange}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>
