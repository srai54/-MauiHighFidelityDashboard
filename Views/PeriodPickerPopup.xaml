<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="MauiHighFidelityDashboard.Views.PeriodPickerPopup"
               CanBeDismissedByTappingOutsideOfPopup="True"
               Color="Transparent">
    <Border BackgroundColor="White"
            Stroke="#E4E8F0"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 12"
            WidthRequest="280"
            Padding="0">
        <Grid RowDefinitions="Auto,1,Auto">
            <!-- Header -->
            <VerticalStackLayout Padding="20,16,20,14" Spacing="2">
                <Label Text="Bounce Rate Period"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="Choose the time range to display"
                       FontSize="11"
                       TextColor="{StaticResource TextLight}" />
            </VerticalStackLayout>
            <BoxView Grid.Row="1" HeightRequest="1" Color="{StaticResource DividerColor}" />

            <!-- Options (rows are built in code-behind so the current one gets a check) -->
            <VerticalStackLayout x:Name="OptionsHost"
                                 Grid.Row="2"
                                 Padding="8,8,8,10"
                                 Spacing="2" />
        </Grid>
    </Border>
</toolkit:Popup>
