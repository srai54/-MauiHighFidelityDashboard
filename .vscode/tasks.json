{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/HighFidelity.Ui.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-windows",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "-f",
        "net10.0-windows10.0.19041.0",
        "${workspaceFolder}/HighFidelity.Ui.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-windows",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "-f",
        "net10.0-windows10.0.19041.0",
        "--project",
        "${workspaceFolder}/HighFidelity.Ui.csproj"
      ],
      "problemMatcher": []
    }
  ]
}
