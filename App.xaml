<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MauiHighFidelityDashboard.Core"
             x:Class="MauiHighFidelityDashboard.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="src/Presentation/Styles/Colors.xaml" />
                <ResourceDictionary Source="src/Presentation/Styles/Styles.xaml" />
                <ResourceDictionary Source="src/Presentation/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:HexToColorConverter x:Key="HexToColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
