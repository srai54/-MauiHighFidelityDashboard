<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="SidebarColor">#0B1A4E</Color>
    <Color x:Key="SidebarText">#8A97B5</Color>
    <Color x:Key="SidebarIcon">#AEB9D0</Color>
    <Color x:Key="PrimaryOrange">#FF5B1F</Color>
    <Color x:Key="BlueAccent">#4FC3F7</Color>
    <Color x:Key="SuccessGreen">#2BC155</Color>
    <Color x:Key="PinkAccent">#EC407A</Color>
    <Color x:Key="YellowAccent">#FFC107</Color>
    <Color x:Key="PurpleAccent">#9C27B0</Color>
    <Color x:Key="RedAccent">#F44336</Color>

    <Color x:Key="PageBackground">#F1F4F9</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>

    <Color x:Key="TextPrimary">#2A2E43</Color>
    <Color x:Key="TextSecondary">#636E72</Color>
    <Color x:Key="TextLight">#9AA3B7</Color>
    <Color x:Key="TextWhite">#FFFFFF</Color>

    <Color x:Key="ChartOnline">#4FC3F7</Color>
    <Color x:Key="ChartStore">#FFA726</Color>

    <Color x:Key="TrafficFacebook">#2196F3</Color>
    <Color x:Key="TrafficYoutube">#FF5722</Color>
    <Color x:Key="TrafficDirect">#FFC107</Color>

    <Color x:Key="StatusProcess">#F7284A</Color>
    <Color x:Key="StatusOpen">#2BC155</Color>
    <Color x:Key="StatusOnHold">#6259CE</Color>

    <!-- Revenue Card Backgrounds + Accents -->
    <Color x:Key="RevenueBlueBg">#E1F0FF</Color>
    <Color x:Key="RevenueBlueAccent">#2196F3</Color>
    <Color x:Key="RevenueYellowBg">#FFF8E1</Color>
    <Color x:Key="RevenueYellowAccent">#FFB822</Color>
    <Color x:Key="RevenueOrangeBg">#FDEADF</Color>
    <Color x:Key="RevenueOrangeAccent">#FF7B43</Color>
    <Color x:Key="RevenuePurpleBg">#F3E8FD</Color>
    <Color x:Key="RevenuePurpleAccent">#A461D8</Color>

    <!-- Design Tokens -->
    <Color x:Key="BorderColor">#EBEEF5</Color>
    <Color x:Key="DividerColor">#EDF0F5</Color>
    <Color x:Key="TableHeaderBg">#F3F6FB</Color>
    <Color x:Key="IconButtonBg">#F4F6FB</Color>
    <Color x:Key="IconButtonText">#6B7694</Color>
    <Color x:Key="SidebarHover">#16295E</Color>
    <Color x:Key="ShadowColor">#1A000000</Color>

    <!-- Semantic Colors -->
    <Color x:Key="DangerColor">#F44336</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FFC107</Color>
    <Color x:Key="InfoColor">#2196F3</Color>
</ResourceDictionary>
