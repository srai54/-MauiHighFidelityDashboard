<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiHighFidelityDashboard.Components.RevenueCardView"
             x:Name="Root">
    <Border StrokeShape="RoundRectangle 6"
            Stroke="Transparent"
            BackgroundColor="{Binding CardBackground, Source={x:Reference Root}}"
            Padding="18,16"
            MinimumHeightRequest="132">
        <Grid RowDefinitions="Auto,*" RowSpacing="10">
            <Label Text="{Binding CardTitle, Source={x:Reference Root}}"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="#4B5574" />

            <!-- Bar variant: mini bars left, value + date range right -->
            <Grid x:Name="BarLayout"
                  Grid.Row="1"
                  ColumnDefinitions="Auto,*"
                  IsVisible="False">
                <GraphicsView x:Name="BarCanvas"
                              WidthRequest="74"
                              HeightRequest="52"
                              VerticalOptions="End" />
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="3"
                                     HorizontalOptions="End"
                                     VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="6" HorizontalOptions="End">
                        <!-- Vector arrow: text "↑" ignores bold because the glyph comes from a fallback font -->
                        <Path x:Name="BarArrow"
                              Data="M7,15.5 L7,2.2 M2.6,6.6 L7,2.2 L11.4,6.6"
                              StrokeThickness="3.2"
                              StrokeLineCap="Round"
                              StrokeLineJoin="Round"
                              WidthRequest="14"
                              HeightRequest="18"
                              VerticalOptions="Center" />
                        <Label Text="{Binding CardValue, Source={x:Reference Root}}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{Binding AccentColor, Source={x:Reference Root}}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding CardSubtitle, Source={x:Reference Root}}"
                           FontSize="10"
                           TextColor="#8B93A7"
                           HorizontalTextAlignment="End" />
                </VerticalStackLayout>
            </Grid>

            <!-- Area variant: value top-left, wave filling the bottom -->
            <Grid x:Name="AreaLayout"
                  Grid.Row="1"
                  RowDefinitions="Auto,*"
                  IsVisible="False">
                <HorizontalStackLayout Spacing="6">
                    <Path x:Name="AreaArrow"
                          Data="M7,15.5 L7,2.2 M2.6,6.6 L7,2.2 L11.4,6.6"
                          StrokeThickness="3.2"
                          StrokeLineCap="Round"
                          StrokeLineJoin="Round"
                          WidthRequest="14"
                          HeightRequest="18"
                          VerticalOptions="Center" />
                    <Label Text="{Binding CardValue, Source={x:Reference Root}}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{Binding AccentColor, Source={x:Reference Root}}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
                <GraphicsView x:Name="AreaCanvas"
                              Grid.Row="1"
                              HeightRequest="44"
                              Margin="-4,8,-4,0"
                              VerticalOptions="End" />
            </Grid>

            <!-- Line variant: value + Monthly dropdown left, squiggle right -->
            <Grid x:Name="LineLayout"
                  Grid.Row="1"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="12"
                  IsVisible="False">
                <VerticalStackLayout Spacing="10" VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="6">
                        <Path x:Name="LineArrow"
                              Data="M7,15.5 L7,2.2 M2.6,6.6 L7,2.2 L11.4,6.6"
                              StrokeThickness="3.2"
                              StrokeLineCap="Round"
                              StrokeLineJoin="Round"
                              WidthRequest="14"
                              HeightRequest="18"
                              VerticalOptions="Center" />
                        <Label Text="{Binding CardValue, Source={x:Reference Root}}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{Binding AccentColor, Source={x:Reference Root}}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Border BackgroundColor="White"
                            Stroke="#E4E8F0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 3"
                            Padding="9,5"
                            HorizontalOptions="Start"
                            ToolTipProperties.Text="Change period">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPeriodChipTapped" />
                        </Border.GestureRecognizers>
                        <Label x:Name="PeriodLabel"
                               Text="Monthly ▾"
                               FontSize="10"
                               TextColor="#6B7694" />
                    </Border>
                </VerticalStackLayout>
                <GraphicsView x:Name="LineCanvas"
                              Grid.Column="1"
                              HeightRequest="56"
                              VerticalOptions="End" />
            </Grid>
        </Grid>
    </Border>
</ContentView>
