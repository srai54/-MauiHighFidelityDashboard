<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MauiHighFidelityDashboard.Converters"
             xmlns:models="clr-namespace:MauiHighFidelityDashboard.Models"
             xmlns:vm="clr-namespace:MauiHighFidelityDashboard.ViewModels"
             x:Class="MauiHighFidelityDashboard.Components.OrderTableView">
    <ContentView.Resources>
        <converters:StatusBackgroundConverter x:Key="StatusBackgroundConverter" />
    </ContentView.Resources>
    <Border Style="{StaticResource CardBorderStyle}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="16">
            <!-- Title -->
            <VerticalStackLayout Spacing="3">
                <Label Text="Order Status"
                       Style="{StaticResource SectionTitle}" />
                <Label Text="Overview of Latest Month"
                       Style="{StaticResource SectionSubtitle}" />
            </VerticalStackLayout>

            <!-- Toolbar (search drops to its own row on narrow screens; see code-behind) -->
            <Grid x:Name="OrdersToolbar"
                  Grid.Row="1"
                  ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="8"
                  RowSpacing="10">
                <Button Text="Add"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="11"
                        Padding="12,0"
                        HeightRequest="32"
                        ContentLayout="Left, 6"
                        Command="{Binding AddOrderCommand}"
                        ToolTipProperties.Text="Add a new order — quick sample or manual entry">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FontAwesome" Glyph="&#xf067;" Color="White" Size="10" />
                    </Button.ImageSource>
                </Button>
                <Button Grid.Column="1" Text="&#xf05a;" Style="{StaticResource IconButtonInfo}"
                        Command="{Binding ShowOrderInfoCommand}"
                        ToolTipProperties.Text="View order summary" />
                <Button Grid.Column="2" Text="&#xf1f8;" Style="{StaticResource IconButtonDanger}" FontSize="12"
                        Command="{Binding DeleteOrderCommand}"
                        ToolTipProperties.Text="Delete selected order (tap a row first)" />
                <Button Grid.Column="3" Text="&#xf02f;" Style="{StaticResource IconButtonPrint}" FontSize="12"
                        Command="{Binding PrintOrdersCommand}"
                        ToolTipProperties.Text="Print order list" />
                <!-- Search field -->
                <Entry x:Name="SearchEntry"
                       Grid.Column="5"
                       Placeholder="Search"
                       Text="{Binding SearchText}"
                       PlaceholderColor="{StaticResource TextLight}"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="11"
                       BackgroundColor="#F1F3F6"
                       WidthRequest="150"
                       HeightRequest="32"
                       VerticalOptions="Center"
                       ToolTipProperties.Text="Filter by invoice, customer, country or status" />
                <Button x:Name="PrintRight" Grid.Column="6" Text="&#xf02f;" Style="{StaticResource IconButtonPrint}" FontSize="12"
                        Command="{Binding PrintOrdersCommand}"
                        ToolTipProperties.Text="Print order list" />
            </Grid>

            <!-- Table (pans horizontally on narrow screens; fills the card on wide ones) -->
            <ScrollView x:Name="TableScroll"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <VerticalStackLayout x:Name="TableContent" Spacing="16">
                    <!-- Table header -->
                    <Border BackgroundColor="{StaticResource TableHeaderBg}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 4"
                            Padding="14,11">
                        <Grid ColumnDefinitions="70,*,90,80,90">
                            <Label Text="INVOICE" Style="{StaticResource TableHeaderLabel}" />
                            <Label Grid.Column="1" Text="CUSTOMERS" Style="{StaticResource TableHeaderLabel}" />
                            <Label Grid.Column="2" Text="FROM" Style="{StaticResource TableHeaderLabel}" />
                            <Label Grid.Column="3" Text="PRICE" Style="{StaticResource TableHeaderLabel}" />
                            <Label Grid.Column="4" Text="STATUS" Style="{StaticResource TableHeaderLabel}" />
                        </Grid>
                    </Border>

                    <!-- Rows (tap to select) -->
                    <VerticalStackLayout Spacing="0"
                                         BindableLayout.ItemsSource="{Binding Orders}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:OrderModel">
                        <Grid RowDefinitions="*,1" Padding="14,0,14,0" BackgroundColor="Transparent">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#FFF1E9" />
                                </DataTrigger>
                            </Grid.Triggers>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectOrderCommand, Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}}"
                                                      CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>
                            <Grid ColumnDefinitions="70,*,90,80,90" HeightRequest="43">
                                <Label Text="{Binding Invoice}" FontSize="12" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Customer}" FontSize="12" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding Country}" FontSize="12" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="{Binding Price, StringFormat='${0:F0}'}" FontSize="12" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Border Grid.Column="4"
                                        BackgroundColor="{Binding Status, Converter={StaticResource StatusBackgroundConverter}}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 3"
                                        WidthRequest="64"
                                        HeightRequest="23"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Status}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                            </Grid>
                            <BoxView Grid.Row="1" HeightRequest="1" Color="{StaticResource DividerColor}" />
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Footer: entries text + pagination -->
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                <Label Text="{Binding OrdersFooterText}"
                       FontSize="11"
                       TextColor="{StaticResource TextLight}"
                       VerticalOptions="Center" />
                <HorizontalStackLayout Grid.Column="1" Spacing="4">
                    <Button Text="‹"
                            Style="{StaticResource PaginationButton}"
                            Command="{Binding PreviousPageCommand}"
                            ToolTipProperties.Text="Previous page" />
                    <HorizontalStackLayout Spacing="4"
                                           BindableLayout.ItemsSource="{Binding PageNumbers}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:PageItem">
                                <Button Text="{Binding Number}"
                                        Style="{StaticResource PaginationButton}"
                                        Command="{Binding GoToPageCommand, Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}}"
                                        CommandParameter="{Binding .}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryOrange}" />
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                    <Button Text="›"
                            Style="{StaticResource PaginationButton}"
                            Command="{Binding NextPageCommand}"
                            ToolTipProperties.Text="Next page" />
                </HorizontalStackLayout>
            </Grid>
        </Grid>
    </Border>
</ContentView>
