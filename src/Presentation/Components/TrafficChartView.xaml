<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiHighFidelityDashboard.Presentation.Components.TrafficChartView">
    <Border Style="{StaticResource CardBorderStyle}" Padding="16">
        <VerticalStackLayout Spacing="16">
            <Label Text="Traffic"
                   Style="{StaticResource SectionTitle}"
                   Margin="0" />
            <Grid HeightRequest="200" HorizontalOptions="Center">
                <GraphicsView x:Name="DonutCanvas"
                              WidthRequest="180"
                              HeightRequest="180"
                              HorizontalOptions="Center"
                              VerticalOptions="Center" />
            </Grid>
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="10">
                    <BoxView WidthRequest="14" HeightRequest="14" Color="{StaticResource TrafficFacebook}" CornerRadius="3" VerticalOptions="Center" />
                    <Label Text="Facebook - 34%" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="10">
                    <BoxView WidthRequest="14" HeightRequest="14" Color="{StaticResource TrafficYoutube}" CornerRadius="3" VerticalOptions="Center" />
                    <Label Text="Youtube - 55%" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="10">
                    <BoxView WidthRequest="14" HeightRequest="14" Color="{StaticResource TrafficDirect}" CornerRadius="3" VerticalOptions="Center" />
                    <Label Text="Direct Search - 11%" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>
