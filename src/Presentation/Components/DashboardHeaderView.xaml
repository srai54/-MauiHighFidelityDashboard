<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiHighFidelityDashboard.Presentation.Components.DashboardHeaderView"
             Padding="24,20">
    <Grid ColumnDefinitions="*,Auto">
        <VerticalStackLayout>
            <Label Text="{Binding DashboardDisplayTitle}"
                   Style="{StaticResource DisplayTitle}" />
            <Label Text="{Binding DashboardSubtitle}"
                   Style="{StaticResource SectionSubtitle}"
                   Margin="0,4,0,0" />
        </VerticalStackLayout>
        <HorizontalStackLayout Grid.Column="1" Spacing="24" VerticalOptions="Center">
            <VerticalStackLayout Spacing="2">
                <Label Text="{Binding CurrentMonthEarnings}"
                        Style="{StaticResource MetricValue}" />
                <Label Text="Current Month Earnings"
                        Style="{StaticResource CaptionText}" />
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="2">
                <Label Text="{Binding CurrentMonthSales}"
                        Style="{StaticResource MetricValue}" />
                <Label Text="Current Month Sales"
                        Style="{StaticResource CaptionText}" />
            </VerticalStackLayout>
            <Button Text="Last Month Summary"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding LastMonthSummaryCommand}"
                    VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Grid>
</ContentView>
