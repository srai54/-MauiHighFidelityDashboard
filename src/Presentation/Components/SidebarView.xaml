<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiHighFidelityDashboard.Presentation.Components.SidebarView"
             BackgroundColor="#071A52"
             WidthRequest="220">
    <ScrollView>
        <VerticalStackLayout Padding="0">
            <VerticalStackLayout Padding="20,24,20,20">
                <Label Text="MAUI DASHBOARD"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold" />
                <BoxView HeightRequest="1"
                         Color="#1A3A6A"
                         Margin="0,12,0,0" />
            </VerticalStackLayout>
            <CollectionView ItemsSource="{Binding MenuItems, Source={x:Reference SidebarSelf}}"
                            x:Name="SidebarSelf">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Padding="20,12" FontSize="14">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Icon}" TextColor="White" />
                                    <Span Text=" " />
                                    <Span Text="{Binding Label}" />
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsActive}"
                                             Value="True">
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="BackgroundColor" Value="#1A3A6A" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsActive}"
                                             Value="False">
                                    <Setter Property="TextColor" Value="#8A9BB5" />
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
