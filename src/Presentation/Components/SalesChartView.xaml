<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:MauiHighFidelityDashboard.Presentation.Components"
             x:Class="MauiHighFidelityDashboard.Presentation.Components.SalesChartView">
    <ContentView.Resources>
        <components:SalesBarHeightConverter x:Key="SalesBarConverter" />
    </ContentView.Resources>
    <Border Style="{StaticResource CardBorderStyle}">
        <VerticalStackLayout Spacing="16">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Sales Analytics"
                       Style="{StaticResource SectionTitle}"
                       Margin="0" />
                <HorizontalStackLayout Grid.Column="1" Spacing="8">
                    <Label Text="&#9670; Online" TextColor="{StaticResource ChartOnline}" FontSize="12" VerticalOptions="Center" />
                    <Label Text="&#9632; Store" TextColor="{StaticResource ChartStore}" FontSize="12" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>
            <HorizontalStackLayout Spacing="16">
                <Label Text="DAILY" TextColor="{StaticResource PrimaryOrange}" FontSize="12" FontAttributes="Bold" />
                <Label Text="WEEKLY" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                <Label Text="MONTHLY" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                <Label Text="YEARLY" TextColor="{StaticResource TextSecondary}" FontSize="12" />
            </HorizontalStackLayout>
            <Border HeightRequest="200"
                    BackgroundColor="{StaticResource PageBackground}"
                    StrokeShape="RoundRectangle 8"
                    Stroke="Transparent">
                <Grid Padding="16">
                    <VerticalStackLayout VerticalOptions="Fill" Spacing="28">
                        <Label Text="30" FontSize="10" TextColor="{StaticResource TextLight}" />
                        <Label Text="20" FontSize="10" TextColor="{StaticResource TextLight}" />
                        <Label Text="10" FontSize="10" TextColor="{StaticResource TextLight}" />
                        <Label Text="0" FontSize="10" TextColor="{StaticResource TextLight}" />
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1"
                                           HorizontalOptions="End"
                                           VerticalOptions="End"
                                           Spacing="12"
                                           HeightRequest="160"
                                           BindableLayout.ItemsSource="{Binding SalesDataPoints}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="4" VerticalOptions="End">
                                    <BoxView WidthRequest="8"
                                             HeightRequest="{Binding Online, Converter={StaticResource SalesBarConverter}}"
                                             Color="{StaticResource ChartOnline}"
                                             CornerRadius="2" />
                                    <BoxView WidthRequest="8"
                                             HeightRequest="{Binding Store, Converter={StaticResource SalesBarConverter}}"
                                             Color="{StaticResource ChartStore}"
                                             CornerRadius="2" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </Border>
</ContentView>
