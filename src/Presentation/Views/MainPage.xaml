<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:MauiHighFidelityDashboard.Presentation.Components"
             xmlns:vm="clr-namespace:MauiHighFidelityDashboard.Core"
             xmlns:models="clr-namespace:MauiHighFidelityDashboard.Domain.Models"
             x:Class="MauiHighFidelityDashboard.Presentation.Views.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False"
             Title="Dashboard">
    <Grid ColumnDefinitions="200,*">
        <components:SidebarView SelectItemCommand="{Binding NavigateCommand}" />

        <ScrollView x:Name="MainScroll" Grid.Column="1">
            <VerticalStackLayout Padding="18" Spacing="16">

                <!-- Row 1: merged Dashboard card (header + spline chart + stat strip) and Traffic card -->
                <Grid ColumnDefinitions="2.55*,1*" ColumnSpacing="16">
                    <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                        <Grid RowDefinitions="*,1,Auto">
                            <Grid ColumnDefinitions="205,*" ColumnSpacing="24" Padding="20,18,20,10">
                                <components:DashboardHeaderView />
                                <components:SalesChartView Grid.Column="1" />
                            </Grid>
                            <BoxView Grid.Row="1" HeightRequest="1" Color="{StaticResource DividerColor}" />
                            <Grid Grid.Row="2"
                                  ColumnDefinitions="*,1,*,1,*,1,*"
                                  Padding="20,16">
                                <components:SummaryCardView BindingContext="{Binding WalletCard}" />
                                <BoxView Grid.Column="1" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView Grid.Column="2" Margin="18,0,0,0" BindingContext="{Binding ReferralCard}" />
                                <BoxView Grid.Column="3" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView Grid.Column="4" Margin="18,0,0,0" BindingContext="{Binding EstimateCard}" />
                                <BoxView Grid.Column="5" WidthRequest="1" Color="{StaticResource DividerColor}" />
                                <components:SummaryCardView Grid.Column="6" Margin="18,0,0,0" BindingContext="{Binding EarningCard}" />
                            </Grid>
                        </Grid>
                    </Border>
                    <components:TrafficChartView Grid.Column="1" />
                </Grid>

                <!-- Row 2: analytics cards (data-driven via BindableLayout ~ add 5th, 6th... by appending to RevenueCards) -->
                <FlexLayout Direction="Row" Wrap="NoWrap" AlignItems="Stretch"
                            BindableLayout.ItemsSource="{Binding RevenueCards}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:RevenueCardItem">
                            <components:RevenueCardView
                                Margin="8,0"
                                CardTitle="{Binding Title}"
                                CardValue="{Binding Value}"
                                CardSubtitle="{Binding Subtitle}"
                                ChartType="{Binding ChartType}"
                                CardBackground="{Binding BackgroundHex, Converter={StaticResource HexToColorConverter}}"
                                AccentColor="{Binding AccentHex, Converter={StaticResource HexToColorConverter}}"
                                FlexLayout.Grow="1" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- Row 3: Recent Activities + Order Status -->
                <Grid ColumnDefinitions="2*,3*" ColumnSpacing="16">
                    <components:ActivityTimelineView />
                    <components:OrderTableView Grid.Column="1" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator Grid.Column="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource PrimaryOrange}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>
