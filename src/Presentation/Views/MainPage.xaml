<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:MauiHighFidelityDashboard.Presentation.Components"
             xmlns:vm="clr-namespace:MauiHighFidelityDashboard.Core.ViewModels"
             xmlns:models="clr-namespace:MauiHighFidelityDashboard.Domain.Models"
             x:Class="MauiHighFidelityDashboard.Presentation.Views.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False"
             Title="Dashboard">
    <Grid ColumnDefinitions="220,*">
        <components:SidebarView SelectItemCommand="{Binding NavigateCommand}" />
        <ScrollView Grid.Column="1">
            <Grid RowDefinitions="Auto,*">
                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource PrimaryOrange}"
                                   HeightRequest="4"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Start" />

                <VerticalStackLayout Grid.Row="1" Spacing="0" Padding="20">
                    <!-- Row 1: Dashboard Header + Sales Chart + Traffic Chart (3-column) -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,0,0,12">
                        <components:DashboardHeaderView />
                        <components:SalesChartView Grid.Column="1" />
                        <components:TrafficChartView Grid.Column="2" />
                    </Grid>

                    <!-- Row 2: KPI Cards (responsive FlexLayout) -->
                    <FlexLayout Wrap="Wrap"
                                JustifyContent="Start"
                                AlignItems="Start"
                                Margin="0,0,0,12"
                                BindableLayout.ItemsSource="{Binding DashboardCards}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:DashboardCard">
                                <components:SummaryCardView WidthRequest="220" Margin="6" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <!-- Row 3: Analytics Cards (responsive FlexLayout) -->
                    <FlexLayout Wrap="Wrap"
                                JustifyContent="Start"
                                AlignItems="Start"
                                Margin="0,0,0,12">
                        <components:RevenueCardView
                            CardTitle="Revenue Status"
                            CardValue="$432"
                            CardSubtitle="Jan 01 - Jan 10"
                            WidthRequest="220" Margin="6"
                            CardBackground="{StaticResource RevenueBlueBg}"
                            ChartBackground="{StaticResource RevenueBlueChart}" />
                        <components:RevenueCardView
                            CardTitle="Page View"
                            CardValue="$432"
                            WidthRequest="220" Margin="6"
                            CardBackground="{StaticResource RevenueYellowBg}"
                            ChartBackground="{StaticResource RevenueYellowChart}" />
                        <components:RevenueCardView
                            CardTitle="Bounce Rate"
                            CardValue="$432"
                            CardSubtitle="Monthly"
                            WidthRequest="220" Margin="6"
                            CardBackground="{StaticResource RevenueOrangeBg}"
                            ChartBackground="{StaticResource RevenueOrangeChart}" />
                        <components:RevenueCardView
                            CardTitle="Revenue Status"
                            CardValue="$432"
                            WidthRequest="220" Margin="6"
                            CardBackground="{StaticResource RevenuePurpleBg}"
                            ChartBackground="{StaticResource RevenuePurpleChart}" />
                    </FlexLayout>

                    <!-- Row 4: Activities (35%) + Orders (65%) -->
                    <Grid ColumnDefinitions="2*,3*" ColumnSpacing="12" Margin="0,0,0,0">
                        <components:ActivityTimelineView />
                        <components:OrderTableView Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
