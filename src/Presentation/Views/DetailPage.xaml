<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiHighFidelityDashboard.Core.ViewModels"
             xmlns:models="clr-namespace:MauiHighFidelityDashboard.Domain.Models"
             x:Class="MauiHighFidelityDashboard.Presentation.Views.DetailPage"
             x:DataType="vm:DetailViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" MaximumWidthRequest="760" HorizontalOptions="Center">
            <HorizontalStackLayout Spacing="4">
                <Button Text="← Back to Dashboard"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource PrimaryOrange}"
                        FontSize="13"
                        Padding="0" />
            </HorizontalStackLayout>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="3">
                    <Label Text="{Binding Title}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="{Binding SectionSubtitle}"
                           FontSize="11"
                           TextColor="{StaticResource TextLight}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Padding="20,8">
                <VerticalStackLayout Spacing="0"
                                     BindableLayout.ItemsSource="{Binding Items}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:SectionItem">
                            <Grid RowDefinitions="*,1" ColumnDefinitions="*,Auto" Padding="0,12">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="{Binding Name}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Detail}"
                                           FontSize="11"
                                           TextColor="{StaticResource TextLight}" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1"
                                        BackgroundColor="{Binding BadgeColorHex, Converter={StaticResource HexToColorConverter}}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 3"
                                        Padding="10,4"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Badge}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </Border>
                                <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,12,0,0" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
